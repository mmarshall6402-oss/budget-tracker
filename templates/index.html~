<!DOCTYPE html>
<html lang="en">
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Budget</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --bg:#0f1117;
  --s1:#161b27;
  --s2:#1e2535;
  --s3:#252d3d;
  --blue:#4d9ef7;
  --blue-dim:#1a2d4a;
  --blue-bright:#7bb8ff;
  --red:#f76d6d;
  --red-dim:#3d1f1f;
  --amber:#f7c44d;
  --amber-dim:#3d2e10;
  --green:#4df7a0;
  --green-dim:#0f3020;
  --text:#e8edf5;
  --muted:#5a6478;
  --border:#232b3d;
  --tab:60px;
}

body{
  font-family:'Inter',sans-serif;
  background:var(--bg);
  color:var(--text);
  height:100dvh;
  overflow:hidden;
  display:flex;
  flex-direction:column;
  font-size:15px;
}

/* ── HEADER ── */
.hdr{
  background:var(--s1);
  border-bottom:1px solid var(--border);
  padding:14px 16px 12px;
  flex-shrink:0;
}

.hdr-row{display:flex;justify-content:space-between;align-items:flex-start;gap:12px}

.bal-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:2px}
.bal-num{font-size:34px;font-weight:700;color:var(--blue-bright);letter-spacing:-.5px;line-height:1}

.hdr-right{text-align:right;flex-shrink:0}
.due-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:2px}
.due-num{font-size:22px;font-weight:600;color:var(--amber)}

.pill{
  display:inline-block;
  font-size:11px;font-weight:600;
  padding:3px 10px;border-radius:20px;
  margin-top:6px;
}
.pill-red{background:var(--red-dim);color:var(--red)}
.pill-green{background:var(--green-dim);color:var(--green)}

/* ── PAGES ── */
.pages{flex:1;overflow:hidden;position:relative}

.page{
  position:absolute;inset:0;bottom:var(--tab);
  overflow-y:auto;padding:12px 12px 20px;
  display:none;
  -webkit-overflow-scrolling:touch;
}
.page.on{display:block}

/* ── TABS ── */
.tabs{
  position:fixed;bottom:0;left:0;right:0;
  height:var(--tab);
  background:var(--s1);
  border-top:1px solid var(--border);
  display:flex;z-index:99;
}
.tab{
  flex:1;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  gap:2px;border:none;background:none;
  color:var(--muted);font-size:10px;font-weight:500;
  letter-spacing:.04em;text-transform:uppercase;
  cursor:pointer;-webkit-tap-highlight-color:transparent;
  transition:color .15s;
}
.tab.on{color:var(--blue)}
.tab svg{width:20px;height:20px;stroke-width:1.8}

/* ── CARDS ── */
.card{
  background:var(--s1);
  border:1px solid var(--border);
  border-radius:14px;
  padding:14px;
  margin-bottom:10px;
}
.card-title{
  font-size:10px;color:var(--muted);
  text-transform:uppercase;letter-spacing:.1em;
  margin-bottom:10px;font-weight:600;
}

/* ── STAT GRID ── */
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.stat{background:var(--s2);border-radius:12px;padding:12px 14px;border:1px solid var(--border)}
.stat-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
.stat-val{font-size:20px;font-weight:700;letter-spacing:-.3px}
.c-blue{color:var(--blue-bright)}
.c-red{color:var(--red)}
.c-amber{color:var(--amber)}
.c-green{color:var(--green)}
.c-muted{color:var(--muted)}

/* ── BILL ROW ── */
.bill{
  display:flex;align-items:center;
  gap:10px;padding:10px 0;
  border-bottom:1px solid var(--border);
}
.bill:last-child{border-bottom:none;padding-bottom:0}

.dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.d-red{background:var(--red)}
.d-amber{background:var(--amber)}
.d-blue{background:var(--blue)}
.d-muted{background:var(--muted)}

.bill-info{flex:1;min-width:0}
.bill-name{font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bill-name.faded{color:var(--muted);text-decoration:line-through}
.bill-sub{font-size:11px;color:var(--muted);margin-top:1px}

.bill-r{text-align:right;flex-shrink:0}
.bill-amt{font-size:14px;font-weight:700}
.bill-btns{display:flex;gap:5px;margin-top:4px;justify-content:flex-end}

/* ── TX ROW ── */
.tx{
  display:flex;align-items:center;
  gap:10px;padding:9px 0;
  border-bottom:1px solid var(--border);
}
.tx:last-child{border-bottom:none;padding-bottom:0}
.tx-icon{
  width:34px;height:34px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:14px;flex-shrink:0;
}
.tx-in{background:var(--green-dim)}
.tx-out{background:var(--red-dim)}
.tx-info{flex:1;min-width:0}
.tx-label{font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tx-date{font-size:11px;color:var(--muted)}
.tx-r{text-align:right;flex-shrink:0}
.tx-amt-in{font-size:14px;font-weight:700;color:var(--green)}
.tx-amt-out{font-size:14px;font-weight:700;color:var(--red)}

/* ── FORMS ── */
.row2{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}

.fld{margin-bottom:10px}
.fld label{font-size:10px;color:var(--muted);display:block;margin-bottom:4px;text-transform:uppercase;letter-spacing:.06em;font-weight:600}

input[type=text],input[type=number],select{
  width:100%;background:var(--s2);
  border:1px solid var(--border);border-radius:10px;
  color:var(--text);font-size:15px;
  padding:10px 12px;font-family:'Inter',sans-serif;
  -webkit-appearance:none;
}
input:focus,select:focus{outline:none;border-color:var(--blue)}

.btn{
  width:100%;padding:13px;
  background:var(--blue);color:#fff;
  font-weight:600;font-size:15px;border:none;
  border-radius:12px;cursor:pointer;
  font-family:'Inter',sans-serif;
}
.btn-ghost{
  background:transparent;color:var(--red);
  border:1px solid var(--red);border-radius:12px;
  width:100%;padding:11px;font-size:14px;
  font-weight:600;cursor:pointer;
  font-family:'Inter',sans-serif;
}

.btn-xs{
  font-size:11px;padding:3px 10px;
  border-radius:20px;border:1px solid var(--border);
  background:var(--s3);color:var(--text);
  cursor:pointer;font-family:'Inter',sans-serif;
}
.btn-xs.b{border-color:var(--blue);color:var(--blue)}
.btn-xs.r{border-color:var(--red);color:var(--red)}

.empty{color:var(--muted);font-size:13px;text-align:center;padding:18px 0}

/* toggle for in/out */
.type-toggle{display:flex;gap:8px;margin-bottom:12px}
.type-btn{
  flex:1;padding:10px;border-radius:10px;
  border:1px solid var(--border);background:var(--s2);
  color:var(--muted);font-weight:600;font-size:14px;
  cursor:pointer;font-family:'Inter',sans-serif;
  transition:all .15s;
}
.type-btn.sel-in{background:var(--green-dim);border-color:var(--green);color:var(--green)}
.type-btn.sel-out{background:var(--red-dim);border-color:var(--red);color:var(--red)}
</style>
</head>
<body>

<!-- HEADER -->
<div class="hdr">
  <div class="hdr-row">
    <div>
      <div class="bal-lbl">Balance</div>
      <div class="bal-num">${{ "%.0f"|format(balance) }}</div>
      {% if bills %}
        {% if shortfall < 0 %}
        <span class="pill pill-red">⚠ ${{ "%.0f"|format(shortfall|abs) }} short on bills</span>
        {% else %}
        <span class="pill pill-green">${{ "%.0f"|format(shortfall) }} left after bills</span>
        {% endif %}
      {% endif %}
    </div>
    <div class="hdr-right">
      <div class="due-lbl">Bills due</div>
      <div class="due-num">${{ "%.0f"|format(upcoming_total) }}</div>
    </div>
  </div>
</div>

<!-- PAGES -->
<div class="pages">

  <!-- ── TODAY TAB ── -->
  <div class="page on" id="pg-today">

    <!-- mini stats -->
    <div class="stat-grid">
      <div class="stat">
        <div class="stat-lbl">Cash in</div>
        <div class="stat-val c-green">${{ "%.0f"|format(transactions | selectattr('type','eq','in') | sum(attribute='amount')) }}</div>
      </div>
      <div class="stat">
        <div class="stat-lbl">Spent</div>
        <div class="stat-val c-red">${{ "%.0f"|format(transactions | selectattr('type','eq','out') | sum(attribute='amount')) }}</div>
      </div>
    </div>

    <!-- add transaction -->
    <div class="card">
      <div class="card-title">Log money</div>
      <form action="/add_transaction" method="POST" id="txform">
        <input type="hidden" name="type" id="txtype" value="out">
        <div class="type-toggle">
          <button type="button" class="type-btn sel-out" id="btn-out" onclick="setType('out')">− Spent</button>
          <button type="button" class="type-btn" id="btn-in" onclick="setType('in')">+ Got paid</button>
        </div>
        <div class="row2">
          <div class="fld">
            <label>Amount $</label>
            <input type="number" name="amount" placeholder="0" step="0.01" required>
          </div>
          <div class="fld">
            <label>What for?</label>
            <input type="text" name="label" placeholder="Food, gas…">
          </div>
        </div>
        <button type="submit" class="btn">Add</button>
      </form>
    </div>

    <!-- recent transactions -->
    <div class="card">
      <div class="card-title">Recent</div>
      {% for t in transactions[:15] %}
      <div class="tx">
        <div class="tx-icon {{ 'tx-in' if t.type == 'in' else 'tx-out' }}">
          {{ '↑' if t.type == 'in' else '↓' }}
        </div>
        <div class="tx-info">
          <div class="tx-label">{{ t.label }}</div>
          <div class="tx-date">{{ t.date }}</div>
        </div>
        <div class="tx-r">
          <div class="{{ 'tx-amt-in' if t.type == 'in' else 'tx-amt-out' }}">
            {{ '+' if t.type == 'in' else '-' }}${{ "%.0f"|format(t.amount) }}
          </div>
          <div style="margin-top:4px">
            <form action="/delete_transaction/{{ t.id }}" method="POST" style="display:inline">
              <button type="submit" class="btn-xs r">del</button>
            </form>
          </div>
        </div>
      </div>
      {% else %}
      <div class="empty">Nothing logged yet</div>
      {% endfor %}
    </div>
  </div>

  <!-- ── BILLS TAB ── -->
  <div class="page" id="pg-bills">

    <div class="card">
      <div class="card-title">What you owe</div>
      {% for b in bills %}
      <div class="bill">
        <div class="dot {{ 'd-muted' if b.paid else ('d-red' if b.due_days <= 5 else ('d-amber' if b.due_days <= 14 else 'd-blue')) }}"></div>
        <div class="bill-info">
          <div class="bill-name {{ 'faded' if b.paid }}">{{ b.name }}</div>
          <div class="bill-sub">{% if b.paid %}paid{% else %}due in {{ b.due_days }}d{% endif %}</div>
        </div>
        <div class="bill-r">
          <div class="bill-amt {{ 'c-muted' if b.paid else ('c-red' if b.due_days <= 5 else ('c-amber' if b.due_days <= 14 else 'c-blue')) }}">${{ "%.0f"|format(b.amount) }}</div>
          <div class="bill-btns">
            <form action="/mark_paid/{{ b.id }}" method="POST" style="display:inline">
              <button class="btn-xs b">{{ 'undo' if b.paid else 'paid' }}</button>
            </form>
            <form action="/delete_bill/{{ b.id }}" method="POST" style="display:inline">
              <button class="btn-xs r">del</button>
            </form>
          </div>
        </div>
      </div>
      {% else %}
      <div class="empty">No bills added yet</div>
      {% endfor %}
    </div>

    <div class="card">
      <div class="card-title">Add a bill</div>
      <form action="/add_bill" method="POST">
        <div class="fld">
          <label>What is it?</label>
          <input type="text" name="bill_name" placeholder="Phone bill, parking ticket…" required>
        </div>
        <div class="row2">
          <div class="fld">
            <label>Amount $</label>
            <input type="number" name="bill_amount" placeholder="0" step="0.01" required>
          </div>
          <div class="fld">
            <label>Due in days</label>
            <input type="number" name="due_days" placeholder="e.g. 7" required>
          </div>
        </div>
        <button type="submit" class="btn">Add Bill</button>
      </form>
    </div>
  </div>

  <!-- ── SETTINGS TAB ── -->
  <div class="page" id="pg-settings">
    <div class="card">
      <div class="card-title">Starting cash</div>
      <form action="/set_cash" method="POST">
        <div class="fld">
          <label>I currently have $</label>
          <input type="number" step="0.01" name="cash" value="{{ cash }}" required>
        </div>
        <button type="submit" class="btn">Save</button>
      </form>
    </div>

    <div class="card">
      <div class="card-title">Reset</div>
      <form action="/clear_transactions" method="POST">
        <button type="submit" class="btn-ghost">Clear all transactions & reset balance</button>
      </form>
    </div>
  </div>

</div>

<!-- BOTTOM TABS -->
<div class="tabs">
  <button class="tab on" onclick="go('today',this)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
    Today
  </button>
  <button class="tab" onclick="go('bills',this)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
    Bills
  </button>
  <button class="tab" onclick="go('settings',this)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
    Settings
  </button>
</div>

<script>
function go(name, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('on'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('on'));
  document.getElementById('pg-' + name).classList.add('on');
  el.classList.add('on');
}

function setType(t) {
  document.getElementById('txtype').value = t;
  const bOut = document.getElementById('btn-out');
  const bIn = document.getElementById('btn-in');
  if (t === 'out') {
    bOut.className = 'type-btn sel-out';
    bIn.className = 'type-btn';
  } else {
    bIn.className = 'type-btn sel-in';
    bOut.className = 'type-btn';
  }
}
</script>
</body>
</html>
